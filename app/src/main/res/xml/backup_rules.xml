<?xml version="1.0" encoding="utf-8"?>
<!--
    Auto Backup rules. Keep includes lint-valid; narrow once real DB/cache
    filenames exist on device.
-->
<full-backup-content>
    <!--
        Lint requires every <exclude> to sit under an included subtree.
        Until real on-disk paths exist, keep this broad-but-valid; tighten
        once databases/caches are implemented.
    -->
    <include domain="sharedpref" path="." />
    <include domain="database" path="." />
    <include domain="file" path="." />
</full-backup-content>
